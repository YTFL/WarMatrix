{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py",
      "routePrefix": "/backend",
      "framework": "fastapi"
    }
  },
  "routes": [
    {
      "src": "/backend/(.*)",
      "dest": "/backend/$1",
      "continue": true
    }
  ]
}
